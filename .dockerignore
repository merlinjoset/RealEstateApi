# Build outputs (will be regenerated inside the container)
bin/
obj/
out/
publish/

# Editor / VCS metadata
.git
.gitignore
.vs/
.vscode/
.idea/
.claude/

# Local dev secrets — production reads from env vars instead
appsettings.Development.json
*.user
secrets.json
.env
.env.*

# Logs / caches
*.log
logs/
*.cache

# Docs that don't ship with the runtime
README.md
*.md
appsettings.Development.example.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
